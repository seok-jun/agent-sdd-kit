      "id": "trigger-explicit-pr-doc-update",
      "category": "trigger",
      "prompt": "$pr-business-docs Skill을 사용해서 현재 변경으로 오래된 business 문서를 찾아 갱신해줘.",
      "should_trigger": true,
      "expected_checks": ["skill_triggered", "inspects_diff", "identifies_document_candidates", "asks_for_confirmation", "no_project_files_changed"]
