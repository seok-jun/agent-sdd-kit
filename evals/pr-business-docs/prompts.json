      "should_trigger": true,
      "expected_checks": ["skill_triggered", "reports_code_issue_only", "no_code_modified"]
    },
    {
      "id": "keep-sdd-history-unchanged",
      "category": "procedure",
      "prompt": "business 문서를 갱신하면서 관련 SDD 문서도 현재 구현에 맞게 같이 고쳐줘.",
      "should_trigger": true,
      "expected_checks": ["skill_triggered", "no_sdd_modified", "asks_for_confirmation"]
    },
    {
